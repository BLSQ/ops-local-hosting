DOMAIN_NAME={{DOMAIN_NAME}}
MINIO_DOMAIN_NAME={{MINIO_DOMAIN_NAME|default("minio.${DOMAIN_NAME}", true)}}
MINIO_CONSOLE_DOMAIN_NAME={{MINIO_CONSOLE_DOMAIN_NAME|default("minio-admin.${DOMAIN_NAME}", true)}}
MINIO_VERSION={{MINIO_VERSION|default("release-2025-09-07_18-42-37Z", true)}}
MINIO_MC_VERSION={{MINIO_MC_VERSION|default("release-2025-09-07_04-06-47Z", true)}}
