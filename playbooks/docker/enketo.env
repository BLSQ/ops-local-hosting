DOMAIN_NAME={{DOMAIN_NAME}}
ENKETO_VERSION={{ENKETO_VERSION|default("4.1.1-4", true)}}
ENKETO_REDIS_VERSION={{ENKETO_REDIS_VERSION|default("5", true)}}
ENKETO_DOMAIN_NAME={{ENKETO_DOMAIN_NAME|default("enketo.${DOMAIN_NAME}", true)}}
ENKETO_API_KEY={{ENKETO_API_KEY}}
ENKETO_LINKED_FORM_AND_DATA_SERVER_API_KEY={{ENKETO_LINKED_FORM_AND_DATA_SERVER_API_KEY|default("{{ENKETO_API_KEY}}", true)}}
ENKETO_LINKED_FORM_AND_DATA_SERVER_NAME={{ENKETO_LINKED_FORM_AND_DATA_SERVER_NAME|default("IASO", true)}}
ENKETO_LINKED_FORM_AND_DATA_SERVER_SERVER_URL={{ENKETO_LINKED_FORM_AND_DATA_SERVER_SERVER_URL|default("iaso.${DOMAIN_NAME}", true)}}